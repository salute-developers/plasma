{
    "parser": "typescript",
    "arrowParens": "always",
    "printWidth": 120,
    "jsxBracketSameLine": false,
    "jsxSingleQuote": false,
    "endOfLine": "auto",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "all",
    "overrides": [
        {
            "files": ["package.json", "**/package.json"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
