{
    "minify": false,
    "jsc": {
        "target": "es2020",
        "parser": {
            "syntax": "typescript",
            "tsx": true
        },
        "baseUrl": ".",
        "paths": {
            "styled-components": ["node_modules/styled-components"]
        },
        "experimental": {
            "plugins": [["@swc/plugin-emotion", { "sourceMap": false }]]
        }
    },
    "exclude": [".*\\.stories.tsx$", ".*\\.component-test.tsx$"]
}
