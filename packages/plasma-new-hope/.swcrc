{
  "minify": false,
  "jsc": {
    "target": "es5",
    "parser": {
        "syntax": "typescript",
    },
    "experimental": {
      "plugins": [
        ["@swc/plugin-emotion", {}],
        ["@swc/plugin-styled-components",
          {
            "displayName": true,
            "ssr": true
          }
        ]
      ]
    }
  }
}
